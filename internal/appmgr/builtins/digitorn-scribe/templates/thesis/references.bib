% =====================================================================
% Scribe — thesis bibliography starter.
%
% Conventions:
%   - Keys: CamelCase author + year, e.g., Knuth1984 / GoodfellowEtAl2016.
%     NEVER use underscores (special in TeX).
%   - Title case in titles (let biblatex re-case to match the style).
%   - Use braces around proper nouns to prevent biblatex lowercasing:
%       title = {Deep learning for {LaTeX} rendering},
%   - DOI / URL fields where possible.
%   - For arxiv: ``eprint = {2401.12345}, eprinttype = {arxiv}``.
% =====================================================================

@book{Knuth1984,
  author    = {Knuth, Donald E.},
  title     = {The {TeX}book},
  year      = {1984},
  publisher = {Addison-Wesley},
  isbn      = {978-0201134476}
}

@article{Lamport1985,
  author  = {Lamport, Leslie},
  title   = {{LaTeX}: A document preparation system},
  year    = {1985},
  journal = {Communications of the ACM},
  volume  = {28},
  number  = {7},
  pages   = {663--665}
}
