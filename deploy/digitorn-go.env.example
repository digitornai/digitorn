# Secrets + instance URLs for the Go daemon. Copy to /etc/digitorn/digitorn-go.env
# on the box (chmod 600, owned by digitorn). systemd loads it via EnvironmentFile.
# Every DIGITORN_SECTION__KEY overrides the matching key in digitorn-go.yaml
# (double underscore = nesting: WORKERS__LLM__GATEWAY_URL -> workers.llm.gateway_url).

# --- Database: a DEDICATED Postgres database for the Go daemon ---
DIGITORN_DATABASE__DRIVER=postgres
DIGITORN_DATABASE__DSN=host=127.0.0.1 user=digitorn_go password=CHANGE_ME dbname=digitorn_go port=5432 sslmode=disable

# --- LLM gateway (the routing layer to every provider) ---
DIGITORN_WORKERS__LLM__GATEWAY_URL=https://gateway.digitorn.ai

# --- Auth: validate JWTs issued by the central digitorn-auth service ---
# Gating is `auth.enabled` (NOT server.auth_enabled, which is a different/unused
# flag). dev_mode defaults TRUE (insecure) — force it false in prod so requests
# without a valid token are rejected. ISSUER must EXACTLY match the token's `iss`
# claim, which is the bare string "digitorn" (not a URL); JWKS still comes from
# the auth service URL (it takes precedence over OIDC discovery).
DIGITORN_AUTH__ENABLED=true
DIGITORN_AUTH__DEV_MODE=false
DIGITORN_AUTH__ISSUER=digitorn
DIGITORN_AUTH__JWKS_URL=https://auth.digitorn.ai/.well-known/jwks.json
DIGITORN_AUTH__SERVICE_URL=https://auth.digitorn.ai
# Leave audience unset unless the auth service stamps a specific `aud` claim —
# a wrong value rejects every token. The legacy daemon does not enforce it.
# DIGITORN_AUTH__AUDIENCE=

# --- Socket.IO horizontal scaling (optional; reuse the box Redis) ---
DIGITORN_SOCKETIO__REDIS_URL=redis://127.0.0.1:6379/1

# --- Background service (digitorn-background): channels + schedules ---
# The background service wakes channel- and schedule-bound sessions by calling the
# daemon AS the end-user (X-Act-As-User). The daemon authorises that ONLY for a
# credential carrying the impersonation grant, so DIGITORN_BG_SERVICE_JWT must be a
# dedicated SERVICE token (role "service" or permission "sessions:impersonate") —
# NEVER a human/admin token. Without it, every user-owned wake is rejected 403
# (the service logs a warning at boot). Leave empty only with auth disabled (dev).
DIGITORN_BG_SERVICE_JWT=
DIGITORN_BG_DAEMON_URL=http://127.0.0.1:8000
# Bearer required on every /ops route (the management + observability API).
DIGITORN_BG_OPS_TOKEN=CHANGE_ME
# Postgres in prod (shares the daemon's DB box); SQLite is the local default.
# DIGITORN_BG_DB_DRIVER=postgres
# DIGITORN_BG_DB_DSN=host=127.0.0.1 user=digitorn_go password=CHANGE_ME dbname=digitorn_go port=5432 sslmode=disable

# --- Any provider/API secrets the runtime needs go here too, e.g.: ---
# ANTHROPIC_API_KEY=...
