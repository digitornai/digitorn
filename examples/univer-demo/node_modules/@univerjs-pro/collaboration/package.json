{
  "name": "@univerjs-pro/collaboration",
  "version": "0.25.1",
  "private": false,
  "description": "Shared collaboration models, resources, and services for Univer Pro.",
  "author": "DreamNum Co., Ltd. <developer@univer.ai>",
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/univer"
  },
  "homepage": "https://univer.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/dream-num/univer"
  },
  "bugs": {
    "url": "https://github.com/dream-num/univer/issues"
  },
  "keywords": [
    "univer",
    "univer-pro",
    "collaboration",
    "realtime",
    "plugin"
  ],
  "exports": {
    ".": {
      "import": "./lib/es/index.js",
      "require": "./lib/cjs/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./*": {
      "import": "./lib/es/*",
      "require": "./lib/cjs/*",
      "types": "./lib/types/index.d.ts"
    },
    "./lib/*": "./lib/*"
  },
  "main": "./lib/es/index.js",
  "types": "./lib/types/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib"
  ],
  "dependencies": {
    "uuid": "^14.0.0",
    "@univerjs-pro/sheets-outline": "0.25.1",
    "@univerjs/data-validation": "0.25.1",
    "@univerjs/core": "0.25.1",
    "@univerjs-pro/license": "0.25.1",
    "@univerjs/docs": "0.25.1",
    "@univerjs/engine-formula": "0.25.1",
    "@univerjs/protocol": "0.25.1",
    "@univerjs/sheets": "0.25.1",
    "@univerjs/sheets-hyper-link": "0.25.1",
    "@univerjs/sheets-drawing": "0.25.1",
    "@univerjs/sheets-filter": "0.25.1",
    "@univerjs/sheets-conditional-formatting": "0.25.1",
    "@univerjs/thread-comment": "0.25.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "@univerjs-infra/shared": "0.25.1",
    "@univerjs/docs-ui": "0.25.1",
    "@univerjs/engine-render": "0.25.1",
    "@univerjs/drawing": "0.25.1"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build:bundle": "univer-cli build",
    "build:types": "tsc -p tsconfig.node.json",
    "build": "pnpm run build:bundle && pnpm run build:types"
  },
  "module": "./lib/es/index.js"
}