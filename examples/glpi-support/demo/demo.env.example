# Copy to demo.env and fill in after first GLPI setup:
#   cp demo.env.example demo.env
#
# Digitorn endpoints (defaults match bin/config.yaml)
DIGITORN_DAEMON_URL=http://127.0.0.1:8000
DIGITORN_BACKGROUND_URL=http://127.0.0.1:8090
DIGITORN_APP_ID=glpi-support
#
# Optional: Bearer JWT if your daemon requires auth for PUT /secrets (Electron login token).
# Leave empty to set secrets manually in the UI.
DIGITORN_TOKEN=

# Shared webhook secret (same in Digitorn Channels + fire-webhook.sh)
GLPI_WEBHOOK_KEY=demo-webhook-secret

# GLPI REST (http://localhost:8080 when using demo/docker-compose.yml)
GLPI_URL=http://localhost:8080
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=
GLPI_SESSION_TOKEN=

# Demo ticket defaults (fire-webhook.sh / create-ticket.sh)
DEMO_TICKET_NAME="VPN ne fonctionne plus"
DEMO_TICKET_CONTENT="Impossible de me connecter au VPN depuis ce matin. Erreur timeout."
DEMO_TICKET_CATEGORY=Network
DEMO_TICKET_USER_ID=2
