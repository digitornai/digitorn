# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
*.log
# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# SQLite databases (daemon state lives in ~/.digitorn, never the repo — but a
# stray relative-path db must never be committed).
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# --- bin/ scratch ---------------------------------------------------------
bin/*.bak*
bin/*.old*
bin/*.preVoiceB
bin/.vite/
bin/_deleted-configs-bak/
bin/digitorn
bin/digitorn-ap-bridge
bin/digitorn-worker
bin/digitorn-worker-embeddings
bin/digitorn-worker-llm
bin/digitorn-worker-tokenizer
bin/digitornd
bin/pieces-bridge/
bin/voice_reply.wav

# Editor/IDE
# .idea/
# .vscode/

# --- vendored sub-projects (excluded from code index / repomap) -----------
activepieces-main/
vendor-references/

# GoReleaser build artifacts (TUI cross-compiled binaries)
.goreleaser-tui/

# Large binaries (exceeds GitHub 100 MB limit)
clients/cli/opencode
clients/cli/digitorn

# Linux cross-compiled binaries
bin-linux/

# Build output
dist/

# Misc heavy files
METADISPATCHER_COMPLETE_REFERENCE.md
digitorn
digitornd
digitorn-background
digitorn-chat.sh

# Digitorn internal bare-repo (git objects/index/refs — never in source control)
.digitorn/git/objects/
.digitorn/git/refs/
.digitorn/git/info/
.digitorn/git/HEAD
.digitorn/git/index
.digitorn/git/packed-refs
.digitorn/git/logs/
.digitorn/git/config
.digitorn/git/description

# All compiled binaries
bin/digitorn-background
bin/digitorn-voice
bin/digitorn-worker-*
bin/digitornd-*
bin/digitorn-ap-bridge
bin/*.cache.*
bin/*.fix.*
bin/*.prev.*
digitorn-worker-llm.exe
digitorn-worker-tokenizer.exe
digitorn-background.exe
digitorn-voice.exe
activepieces-main/
